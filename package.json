{
  "name": "jingot",
  "version": "0.0.0",
  "description": "元宝博客后台接口系统",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "db:create": "cross-env NODE_ENV=development ts-node ./scripts/create-db.ts",
    "db:drop": "cross-env NODE_ENV=development ts-node ./scripts/drop-db.ts",
    "db:init": "cross-env NODE_ENV=development npm run migrate && npm run seed",
    "db:reset": "npm run migrate:undo:all && npm run migrate && npm run seed",
    "db:refresh": "npm run db:drop && npm run db:create && npm run db:init",
    "dev": "cross-env NODE_ENV=development nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "dev:debug": "cross-env DEBUG=jingot:* nodemon src/server.ts",
    "build": "tsc",
    "build:scripts": "tsc --project tsconfig.scripts.json",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "ts-node ./node_modules/sequelize-cli/lib/sequelize db:migrate:undo",
    "migrate:undo:all": "ts-node ./node_modules/sequelize-cli/lib/sequelize db:migrate:undo:all",
    "seed": "ts-node ./node_modules/sequelize-cli/lib/sequelize db:seed:all",
    "seed:serve": "npx sequelize-cli db:seed:all",
    "seed:undo": "ts-node ./node_modules/sequelize-cli/lib/sequelize db:seed:undo",
    "seed:undo:all": "ts-node ./node_modules/sequelize-cli/lib/sequelize db:seed:undo:all",
    "deploy:create": "NODE_ENV=production node ./scripts/create-db.js",
    "deploy:drop": "NODE_ENV=production node ./scripts/drop-db.js",
    "deploy:init": "NODE_ENV=production npm run migrate && NODE_ENV=production npm run seed:serve",
    "deploy:reset": "npm run deploy:drop && npm run deploy:create && npm run deploy:init"
  },
  "_moduleAliases": {
    "@": "./dist"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parse": "^0.4.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^17.3.1",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "morgan": "~1.9.1",
    "multer": "^2.1.1",
    "mysql2": "^3.16.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.3",
    "sequelize-typescript": "^2.1.6",
    "sharp": "^0.34.5",
    "svg-captcha": "^1.4.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.2.2",
    "@types/reflect-metadata": "^0.1.0",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "jingot",
    "express",
    "typescript",
    "sequelize",
    "mysql"
  ],
  "author": "jfx",
  "license": "MIT"
}