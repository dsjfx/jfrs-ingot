# 应用配置
NODE_ENV=development
PORT=3000
APP_NAME=博客后台接口系统

# 数据库配置（示例）
DB_HOST=localhost
DB_PORT=27017
DB_NAME=myapi
DB_USER=
DB_PASSWORD=
DB_DIALECT=mysql
DB_CHARSET=uft8mb4
DB_TIMEZONE=+08:00

DB_LOG_LEVEL=debug
DB_LOG_SLOW_QUERY=100  # 慢查询阈值（毫秒）

# 连接池配置
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUITE=30000
DB_POOL_IDLE=10000

# SSL 配置（生产环境）
DB_SSL_ENABLED=false
DB_SSL_CA_PATH=
DB_SSL_CERT_PATH=
DB_SSL_KEY_PATH=

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=7d

# API配置
API_RATE_LIMIT_WINDOW=15
API_RATE_LIMIT_MAX=100

# 日志级别
LOG_LEVEL=info

# 速率限制
RATE_LIMIT_WINDOW_MS=15*60*1000
RATE_LIMIT_MAX=100

# 压缩配置
COMPRESSION_ENABLED=true
COMPRESSION_THRESHOLD=1024

# Cookie 配置
COOKIE_SECRET=your-cookie-secret-key-change-this
COOKIE_MAX_AGE=86400000 # 24小时

# 静态文件配置
PUBLIC_DIR=
UPLOAD_DIR=